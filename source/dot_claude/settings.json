{
  "effortLevel": "high",
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "claude-powerline@claude-powerline": true,
    "context-mode@context-mode": false,
    "hone@hone-ai": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "serena@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-powerline": {
      "source": {
        "repo": "Owloops/claude-powerline",
        "source": "github"
      }
    },
    "context-mode": {
      "source": {
        "repo": "mksglu/context-mode",
        "source": "github"
      }
    },
    "hone-ai": {
      "source": {
        "repo": "oskarhane/hone-ai",
        "source": "github"
      }
    },
    "karpathy-skills": {
      "source": {
        "repo": "forrestchang/andrej-karpathy-skills",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "mkdir -p ~/.claude/session_starts && jq -r '.session_id' | { read sid; jq -n --arg sid \"$sid\" --arg cwd \"$(pwd)\" --argjson ts $(date +%s) '{\"session_id\":$sid,\"start_time\":$ts,\"cwd\":$cwd}' > ~/.claude/session_starts/\"$PPID\".json; }",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash '/Users/jstegeman/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "model": "sonnet[1m]",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "npx -y @owloops/claude-powerline@latest",
    "type": "command"
  }
}