{
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/session_starts && jq -r '.session_id' | { read sid; jq -n --arg sid \"$sid\" --arg cwd \"$(pwd)\" --argjson ts $(date +%s) '{\"session_id\":$sid,\"start_time\":$ts,\"cwd\":$cwd}' > ~/.claude/session_starts/\"$PPID\".json; }"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/jstegeman/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "claude-powerline@claude-powerline": true,
    "context-mode@context-mode": false,
    "hone@hone-ai": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "serena@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-powerline": {
      "source": {
        "source": "github",
        "repo": "Owloops/claude-powerline"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "hone-ai": {
      "source": {
        "source": "github",
        "repo": "oskarhane/hone-ai"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
