#!/usr/bin/env bash

source "$HOME/.config/sketchybar/variables.sh"

# Detect ultrawide (5120px physical) vs laptop (3456px physical)
SCREEN_WIDTH=$(system_profiler SPDisplaysDataType 2>/dev/null | awk '/Resolution:/{print $2; exit}')
: "${SCREEN_WIDTH:=5120}"

if [ "$SCREEN_WIDTH" -ge 5000 ]; then
    # Ultrawide: keep the bar compact and centered so the groups don't leave a giant empty middle.
    ULTRAWIDE_BAR_WIDTH=1050
    BAR_MARGIN=$(( (SCREEN_WIDTH - ULTRAWIDE_BAR_WIDTH) / 2 ))
    BAR_Y_OFFSET=0
    BAR_PADDING_L=8
    BAR_PADDING_R=8
    LAPTOP_MODE=false
else
    # Laptop: full-width bar in menu bar, keep it minimal because of the notch.
    BAR_MARGIN=0
    BAR_Y_OFFSET=0
    BAR_PADDING_L=680
    BAR_PADDING_R=10
    LAPTOP_MODE=true
fi

sketchybar --bar \
    position=top \
    height=32 \
    blur_radius=0 \
    corner_radius=0 \
    border_width=0 \
    y_offset="$BAR_Y_OFFSET" \
    margin="$BAR_MARGIN" \
    topmost=window \
    padding_left="$BAR_PADDING_L" \
    padding_right="$BAR_PADDING_R" \
    color=0x00000000 \
    shadow=off

# Defaults for all items
sketchybar --default \
    updates=when_shown \
    icon.font="$FONT:Regular:14.0" \
    icon.color="$FOREGROUND" \
    label.font="$FONT:Regular:14.0" \
    label.color="$FOREGROUND" \
    background.corner_radius="$CORNER_RADIUS" \
    background.height=26 \
    background.drawing=off

# Custom events fed by AeroSpace event bridges.
sketchybar --add event aerospace_workspace_changed
sketchybar --add event aerospace_focus_changed
sketchybar --add event aerospace_preset_changed

## Left
source "$ITEM_DIR/spaces.sh"

if [ "$LAPTOP_MODE" = false ]; then
    source "$ITEM_DIR/front_app.sh"
    source "$ITEM_DIR/zone.sh"

    sketchybar --add item spacer.zone_preset left \
        --set spacer.zone_preset width=4 background.drawing=off label.drawing=off icon.drawing=off

    source "$ITEM_DIR/preset.sh"

    ## Right
    source "$ITEM_DIR/mic.sh"
    source "$ITEM_DIR/volume.sh"
    source "$ITEM_DIR/battery.sh"
    source "$ITEM_DIR/calendar.sh"
    source "$ITEM_DIR/clock.sh"
fi

# Kill previous bridge instances (e.g. from a prior reload), then start fresh.
pkill -f "aerospace_bridge.sh" 2>/dev/null
pkill -f "preset_bridge.sh" 2>/dev/null
"$PLUGIN_DIR/aerospace_bridge.sh" &
"$PLUGIN_DIR/preset_bridge.sh" &
disown

sketchybar --update
